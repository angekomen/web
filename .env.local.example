# ============================
# Desarrolladora Aangekomen — .env.local.example
# Copia este archivo como .env.local y completa los valores reales.
# ============================

# Supabase — proyecto del sitio
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Resend — envío de email para leads
RESEND_API_KEY=re_xxx
LEAD_NOTIFY_TO=contacto@aangekomen.mx
# Opcional: dirección "from" verificada en Resend
LEAD_NOTIFY_FROM=Aangekomen <noreply@aangekomen.mx>

# Sitio
NEXT_PUBLIC_SITE_URL=https://aangekomen.mx
